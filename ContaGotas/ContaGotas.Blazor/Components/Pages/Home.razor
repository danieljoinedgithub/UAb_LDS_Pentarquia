@page "/"
@using ContaGotas
@inject Controller Controller
@inject Model Model
@implements IDisposable

<PageTitle>ContaGotas - Médias (MVC)</PageTitle>

<div class="container mt-4">
    @* 1. Se o Controller disparar um erro, mostramos esta caixa vermelha *@
    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="alert alert-danger shadow-sm">
            <h5 class="alert-heading">Oooops! ocorreu um erro!</h5>
            <p class="mb-0">@mensagemErro</p>
        </div>
    }
    @* 2. Se não houver erro, mas a lista continuar nula, mostramos o carregamento *@
    else if (listaMedias == null)
    {
        <div class="d-flex align-items-center gap-2 text-secondary">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>A solicitar dados (isto pode demorar alguns segundos)...</span>
        </div>
    }
    @* 3. Quando os dados chegam com sucesso, desenhamos a tabela *@
    else
    {
        <div class="section">
            <h2>Preços Médios de Combustível</h2>
            <div class="caixa-medias">
               @foreach (var media in listaMedias)
                {
                    var diferencaReal = media.GetDiferencaPreco() / 1000m;
                    var culturaPT = new System.Globalization.CultureInfo("pt-PT");

                    <div>
                        <h5>@media.combustivel</h5>
                        <p>@media.valor</p>
                        
                        @if (diferencaReal > 0)
                        {
                            <small>+ @diferencaReal.ToString("0.000", culturaPT) € que há 15 dias</small>
                        }
                        else if (diferencaReal < 0)
                        {
                            <small>@diferencaReal.ToString("0.000", culturaPT) € que há 15 dias</small>
                        }
                        else
                        {
                            <small>Sem alteração</small>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<PrecoMedioModel>? listaMedias;
    private string? mensagemErro;

    // Mudámos para OnInitializedAsync (assíncrono)
    protected override async Task OnInitializedAsync()
    {
        // 1. Subscrevemos os eventos
        Model.OnMediasProntas += MostrarMediasUI;
        Controller.OnErroOcorrido += MostrarErroUI;

        // 2. AGUARDAMOS que o Controller faça o trabalho, exatamente como na consola!
        await Controller.OpcaoSelecionada(1);
    }

    private void MostrarMediasUI()
    {
        listaMedias = Model.ObterMedias();
        mensagemErro = null;
        InvokeAsync(StateHasChanged);
    }

    private void MostrarErroUI(string erro)
    {
        mensagemErro = erro;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Model.OnMediasProntas -= MostrarMediasUI;
        Controller.OnErroOcorrido -= MostrarErroUI;
    }
}