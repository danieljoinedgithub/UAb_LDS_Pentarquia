@page "/pesquisa"
@rendermode InteractiveServer
@using ContaGotas
@inject Controller Controller
@inject Model Model
@implements IDisposable

<PageTitle>ContaGotas - Pesquisa (MVC)</PageTitle>

<div class="container mt-4">
    
    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="alert alert-danger shadow-sm">
            <h5 class="alert-heading">Falha de Comunicação</h5>
            <p class="mb-0">@mensagemErro</p>
        </div>
    }
    else if (listaTipos == null || listaDistritos == null)
    {
        <div class="d-flex align-items-center gap-2 text-secondary">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>A solicitar filtros ao Controller (isto pode demorar alguns segundos)...</span>
        </div>
    }
    else
    {
        <div class="section">
            <h2>Pesquisa Distrital de Postos</h2>

            <div class="card shadow-sm mb-4 border-0 bg-light">
                <div class="card-body row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold text-secondary">Combustível</label>
                        <select class="form-select" @bind="idTipoEscolhido">
                            <option value="0">-- Selecione o Tipo --</option>
                            @foreach (var tipo in listaTipos)
                            {
                                <option value="@tipo.Id">@tipo.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label fw-semibold text-secondary">Distrito</label>
                        <select class="form-select" @bind="idDistritoEscolhido">
                            <option value="0">-- Selecione o Distrito --</option>
                            @foreach (var distrito in listaDistritos)
                            {
                                <option value="@distrito.Id">@distrito.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100 fw-bold"
                                disabled="@(idTipoEscolhido == 0 || idDistritoEscolhido == 0 || aCarregarPostos)"
                                @onclick="AcionarPesquisaNoController">
                            @if (aCarregarPostos)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                            }
                            else
                            {
                                <span>Pesquisar</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (listaPostos != null)
    {
        <div class="section">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    Postos Encontrados: @listaPostos.Count
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Posto</th>
                            <th>Morada</th>
                            <th class="text-end">Preço</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (!listaPostos.Any())
                        {
                            <tr><td colspan="3" class="text-center p-4">Nenhum posto encontrado.</td></tr>
                        }
                        else
                        {
                            @foreach (var posto in listaPostos)
                            {
                                <tr>
                                    <td class="fw-bold">@posto.Nome</td>
                                    <td class="text-secondary small">@posto.Morada</td>
                                    <td class="text-end fw-bold text-primary">@posto.PrecoString €</td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TipoCombustivelModel>? listaTipos;
    private List<DistritoModel>? listaDistritos;
    private List<PostoModel>? listaPostos;

    // Voltamos aos 'int' limpos, como deve ser!
    private int idTipoEscolhido = 0;
    private int idDistritoEscolhido = 0;
    private bool aCarregarPostos = false;
    private string? mensagemErro;

    protected override async Task OnInitializedAsync()
    {
        Model.OnTiposDistritos += AtualizarDropdownsUI;
        Model.ReadyPostos += MostrarResultadosUI;
        Controller.OnErroOcorrido += MostrarErroUI;
        
        await Controller.OpcaoSelecionada(2);
    }

    private void AtualizarDropdownsUI()
    {
        listaTipos = Model.ObterTipos();
        listaDistritos = Model.ObterDistritos();
        mensagemErro = null;
        InvokeAsync(StateHasChanged);
    }

    private void MostrarResultadosUI()
    {
        listaPostos = Model.ObterPostos();
        aCarregarPostos = false;
        mensagemErro = null;
        InvokeAsync(StateHasChanged);
    }

    private void MostrarErroUI(string erro)
    {
        mensagemErro = erro;
        aCarregarPostos = false;
        InvokeAsync(StateHasChanged);
    }

    private void AcionarPesquisaNoController()
    {
        aCarregarPostos = true;
        listaPostos = null;
        mensagemErro = null;
        
        Controller.PesquisaDistrital(idTipoEscolhido, idDistritoEscolhido);
    }

    public void Dispose()
    {
        Model.OnTiposDistritos -= AtualizarDropdownsUI;
        Model.ReadyPostos -= MostrarResultadosUI;
        Controller.OnErroOcorrido -= MostrarErroUI;
    }
}